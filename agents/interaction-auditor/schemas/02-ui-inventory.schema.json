{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interaction Auditor UI Inventory",
  "type": "object",
  "required": ["surfaces"],
  "properties": {
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "source_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "coverage": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
